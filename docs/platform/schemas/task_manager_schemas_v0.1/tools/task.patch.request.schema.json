{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/task-manager/schemas/v0.1/tools/task.patch.request.schema.json",
  "title": "task.patch Request",
  "description": "请求包络：更新任务状态。首期采用操作数组模式。",
  "$defs": {
    "setOp": {
      "type": "object",
      "required": [
        "op",
        "path",
        "value"
      ],
      "properties": {
        "op": {
          "const": "set"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "appendOp": {
      "type": "object",
      "required": [
        "op",
        "path",
        "value"
      ],
      "properties": {
        "op": {
          "const": "append"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "removeOp": {
      "type": "object",
      "required": [
        "op",
        "path"
      ],
      "properties": {
        "op": {
          "const": "remove"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        }
      },
      "additionalProperties": false
    },
    "operation": {
      "oneOf": [
        {
          "$ref": "#/$defs/setOp"
        },
        {
          "$ref": "#/$defs/appendOp"
        },
        {
          "$ref": "#/$defs/removeOp"
        }
      ]
    }
  },
  "allOf": [
    {
      "$ref": "../common/base.schema.json#/$defs/requestEnvelope"
    },
    {
      "type": "object",
      "properties": {
        "input": {
          "type": "object",
          "required": [
            "task_id",
            "ops"
          ],
          "properties": {
            "task_id": {
              "$ref": "../common/base.schema.json#/$defs/nonEmptyString"
            },
            "ops": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/operation"
              }
            }
          },
          "additionalProperties": false
        }
      }
    }
  ],
  "examples": [
    {
      "schema_version": "1.0",
      "request_id": "req-201",
      "trace_id": "trace-200",
      "task_id": "task-200",
      "caller": "task_manager",
      "input": {
        "task_id": "task-200",
        "ops": [
          {
            "op": "set",
            "path": "status",
            "value": "running"
          },
          {
            "op": "set",
            "path": "current_step",
            "value": "summarizing"
          },
          {
            "op": "append",
            "path": "events",
            "value": {
              "type": "memory_search_completed",
              "at": "2026-03-14T08:01:00Z",
              "summary": "已检索到 8 个候选片段。"
            }
          }
        ]
      }
    }
  ]
}
