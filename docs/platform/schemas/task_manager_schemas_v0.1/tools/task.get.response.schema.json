{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/task-manager/schemas/v0.1/tools/task.get.response.schema.json",
  "title": "task.get Response",
  "description": "响应包络：返回任务状态或错误。",
  "$defs": {
    "successData": {
      "type": "object",
      "required": [
        "task_id",
        "status",
        "goal",
        "current_step",
        "context_summary",
        "artifacts",
        "events",
        "updated_at"
      ],
      "properties": {
        "task_id": {
          "$ref": "../common/base.schema.json#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "../common/base.schema.json#/$defs/taskStatus"
        },
        "goal": {
          "$ref": "../common/base.schema.json#/$defs/nonEmptyString"
        },
        "current_step": {
          "oneOf": [
            {
              "$ref": "../common/base.schema.json#/$defs/nonEmptyString"
            },
            {
              "type": "null"
            }
          ]
        },
        "context_summary": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "../common/base.schema.json#/$defs/artifact"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "../common/base.schema.json#/$defs/taskEvent"
          }
        },
        "result_summary": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "updated_at": {
          "$ref": "../common/base.schema.json#/$defs/dateTime"
        }
      },
      "additionalProperties": false
    },
    "successEnvelope": {
      "allOf": [
        {
          "$ref": "../common/base.schema.json#/$defs/responseEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "task.get"
            },
            "status": {
              "const": "ok"
            },
            "data": {
              "$ref": "#/$defs/successData"
            },
            "error": {
              "type": "null"
            }
          }
        }
      ]
    },
    "errorEnvelope": {
      "allOf": [
        {
          "$ref": "../common/base.schema.json#/$defs/responseEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "task.get"
            },
            "status": {
              "const": "error"
            },
            "data": {
              "type": "null"
            },
            "error": {
              "$ref": "../common/base.schema.json#/$defs/errorObject"
            }
          }
        }
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/successEnvelope"
    },
    {
      "$ref": "#/$defs/errorEnvelope"
    }
  ],
  "examples": [
    {
      "schema_version": "1.0",
      "request_id": "req-200",
      "tool": "task.get",
      "status": "ok",
      "data": {
        "task_id": "task-200",
        "status": "running",
        "goal": "总结项目 A 的设备 X 校准条件",
        "current_step": "reading_memory",
        "context_summary": "已完成候选文档检索，正在读取前 3 个片段。",
        "artifacts": [],
        "events": [],
        "updated_at": "2026-03-14T08:00:00Z"
      },
      "error": null,
      "meta": {
        "duration_ms": 10,
        "warnings": []
      }
    }
  ]
}
